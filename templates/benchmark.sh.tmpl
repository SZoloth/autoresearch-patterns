#!/usr/bin/env bash
set -euo pipefail

# Autoresearch benchmark harness for: {{name}}
# Runs the eval command with a timeout and outputs METRIC lines.
# DO NOT MODIFY — this file is generated by init.sh.

TIMEOUT={{timeout}}

# Write eval command to a temp script to avoid quoting issues
_AR_SCRIPT=$(mktemp)
trap 'rm -f "$_AR_SCRIPT"' EXIT

{{#if has_extractor}}
# Metric extraction handled automatically ({{metric.extract}})
cat > "$_AR_SCRIPT" << '_AR_EVAL_EOF'
{{extraction_block}}
_AR_EVAL_EOF
{{/if}}
{{#unless has_extractor}}
cat > "$_AR_SCRIPT" << '_AR_EVAL_EOF'
{{eval}}
_AR_EVAL_EOF
{{/unless}}

if ! timeout "${TIMEOUT}s" bash "$_AR_SCRIPT" > .autoresearch_output 2>&1; then
    echo "EVAL FAILED (exit code $? or timeout)" >&2
    cat .autoresearch_output >&2
    cp .autoresearch_output last_run.log 2>/dev/null || true
    exit 1
fi

cp .autoresearch_output last_run.log
OUTPUT=$(cat last_run.log)
rm -f .autoresearch_output

# Output non-METRIC lines as context, then METRIC lines.
echo "$OUTPUT" | grep -v "^METRIC " || true

if echo "$OUTPUT" | grep -q "^METRIC "; then
    echo "$OUTPUT" | grep "^METRIC "
else
{{#unless has_extractor}}
    echo "WARNING: No METRIC line found in output. Add 'echo METRIC {{metric.name}}=<value>' to your eval command." >&2
    echo "$OUTPUT" | tail -5 >&2
{{/unless}}
    exit 1
fi
