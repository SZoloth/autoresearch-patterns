#!/usr/bin/env bash
set -euo pipefail

# Resolve real path through symlinks
SELF="$0"
[[ -L "$SELF" ]] && SELF="$(readlink "$SELF")"
AUTORESEARCH_HOME="$(cd "$(dirname "$SELF")/.." && pwd)"

usage() {
    echo "Usage: autoresearch <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init [--dry-run] [lab.yaml]   Initialize an autoresearch session"
    echo "  test                          Run benchmark.sh once and show result"
    echo "  calibrate [--runs N]          Validate benchmark stability before optimization"
    echo "  start [--agent <name>]        Launch an agent to optimize"
    echo "  status                        Show session summary and results"
    echo "  learn                         Extract lessons from session to ~/.autoresearch/skills.md"
    echo "  examples                      List available example configs"
    echo "  examples copy <name>          Copy an example to ./lab.yaml"
    echo "  help                          Show this help"
    echo ""
    echo "Typical flow: init → test → calibrate → start"
    echo "If no lab.yaml exists, interactive setup will guide you."
}

case "${1:-help}" in
    init)
        shift
        exec "$AUTORESEARCH_HOME/init.sh" "$@"
        ;;
    test)
        if [[ ! -f benchmark.sh ]]; then
            echo "Error: benchmark.sh not found. Run 'autoresearch init' first." >&2
            exit 1
        fi

        echo "Running benchmark..."
        echo ""

        OUTPUT=$(bash benchmark.sh 2>&1) || {
            echo "$OUTPUT"
            echo ""
            echo "Benchmark failed. Check your eval command." >&2
            exit 1
        }

        # Extract METRIC lines
        METRIC_LINE=$(echo "$OUTPUT" | grep "^METRIC " | tail -1 || true)
        NON_METRIC=$(echo "$OUTPUT" | grep -v "^METRIC " || true)

        if [[ -n "$NON_METRIC" ]]; then
            echo "$NON_METRIC"
            echo ""
        fi

        if [[ -z "$METRIC_LINE" ]]; then
            echo "No METRIC line found in output." >&2
            exit 1
        fi

        # Parse METRIC name=value
        METRIC_PAIR="${METRIC_LINE#METRIC }"
        METRIC_KEY="${METRIC_PAIR%%=*}"
        METRIC_VAL="${METRIC_PAIR#*=}"

        # Use Python TUI for formatted output with comparison
        python3 -c "
import sys; sys.path.insert(0, '$AUTORESEARCH_HOME/lib')
from tui import format_test_result, BOLD_WHITE, DIM, RESET
from status import read_results, extract_best_and_baseline

metric_key = '$METRIC_KEY'
metric_val = '$METRIC_VAL'
unit = ''
direction = 'lower'
best = None
baseline = None

try:
    from parse_config import parse_config
    c = parse_config('lab.yaml')
    unit = c['metric'].get('unit', '')
    direction = c['metric'].get('direction', 'lower')
except Exception:
    pass

results = read_results('results.tsv')
if results:
    best, baseline = extract_best_and_baseline(results, metric_key, direction)

print(format_test_result(metric_key, metric_val, unit, direction, best, baseline))
print()
if best is None:
    print(f'  {DIM}Baseline recorded.{RESET} Run {BOLD_WHITE}autoresearch calibrate{RESET} to validate stability.')
else:
    print(f'  Run {BOLD_WHITE}autoresearch status{RESET} for full results.')
print()
" 2>/dev/null || {
            # Fallback if python fails
            echo "  Result: ${METRIC_KEY} = ${METRIC_VAL}"
            echo ""
            echo "Setup verified. Run 'autoresearch start' to begin optimization."
        }
        ;;
    calibrate)
        shift || true
        if [[ ! -f benchmark.sh ]]; then
            echo "Error: benchmark.sh not found. Run 'autoresearch init' first." >&2
            exit 1
        fi
        exec python3 "$AUTORESEARCH_HOME/lib/calibrate.py" "$@"
        ;;
    start)
        shift || true
        AGENT=""
        SKIP_CAL=false

        # Parse flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --agent) AGENT="$2"; shift 2 ;;
                --skip-calibration) SKIP_CAL=true; shift ;;
                *) echo "Unknown option: $1" >&2; exit 1 ;;
            esac
        done

        if [[ ! -f program.md ]]; then
            echo "Error: program.md not found. Run 'autoresearch init' first." >&2
            exit 1
        fi

        # Soft calibration gate
        if [[ ! -f calibration.md ]] && [[ "$SKIP_CAL" != true ]]; then
            echo "Note: no calibration.md found."
            echo "  Run 'autoresearch calibrate' to validate your benchmark first."
            echo "  Or use 'autoresearch start --skip-calibration' to skip."
            echo ""
        fi

        if [[ -f calibration.md ]]; then
            PROMPT='Read program.md and calibration.md, then follow the instructions in program.md exactly. Use the calibrated baseline from calibration.md as your reference point.'
        else
            PROMPT='Read program.md and follow the instructions exactly.'
        fi

        # Auto-detect agent if not specified
        if [[ -z "$AGENT" ]]; then
            if command -v claude &>/dev/null; then
                AGENT="claude"
            elif command -v codex &>/dev/null; then
                AGENT="codex"
            fi
        fi

        case "${AGENT}" in
            claude)
                echo "Launching Claude Code..."
                exec claude "$PROMPT"
                ;;
            codex)
                echo "Launching Codex..."
                exec codex "$PROMPT"
                ;;
            "")
                echo "No supported agent found (checked: claude, codex)."
                echo ""
                echo "Start manually with any agent:"
                echo "  claude \"$PROMPT\""
                echo "  codex  \"$PROMPT\""
                echo "  cursor  # open program.md and tell the agent to follow it"
                ;;
            *)
                echo "Unknown agent: $AGENT" >&2
                echo "Supported: claude, codex" >&2
                echo ""
                echo "Or start manually:"
                echo "  $AGENT \"$PROMPT\""
                exit 1
                ;;
        esac
        ;;
    status)
        exec python3 "$AUTORESEARCH_HOME/lib/status.py" "${2:-lab.yaml}"
        ;;
    learn)
        if [[ ! -f results.tsv ]]; then
            echo "Error: results.tsv not found. Run experiments first." >&2
            exit 1
        fi
        exec python3 "$AUTORESEARCH_HOME/lib/learn.py" "${2:-lab.yaml}"
        ;;
    examples)
        shift || true
        if [[ "${1:-}" == "copy" ]]; then
            NAME="${2:-}"
            if [[ -z "$NAME" ]]; then
                echo "Usage: autoresearch examples copy <name>" >&2
                echo "Run 'autoresearch examples' to see available configs." >&2
                exit 1
            fi
            [[ "$NAME" != *.yaml ]] && NAME="${NAME}.yaml"
            SRC="$AUTORESEARCH_HOME/examples/$NAME"
            if [[ ! -f "$SRC" ]]; then
                echo "Error: example '$NAME' not found." >&2
                echo "Available:" >&2
                ls -1 "$AUTORESEARCH_HOME/examples/" >&2
                exit 1
            fi
            cp "$SRC" ./lab.yaml
            echo "Copied $NAME to ./lab.yaml — edit it, then run 'autoresearch init'"
        else
            echo "Available example configs:"
            echo ""
            for f in "$AUTORESEARCH_HOME/examples/"*.yaml; do
                name=$(basename "$f" .yaml)
                desc=$(grep '^description:' "$f" | head -1 | cut -d: -f2- | xargs)
                printf "  %-25s %s\n" "$name" "${desc:-(no description)}"
            done
            echo ""
            echo "Copy one: autoresearch examples copy <name>"
        fi
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        echo ""
        usage >&2
        exit 1
        ;;
esac
